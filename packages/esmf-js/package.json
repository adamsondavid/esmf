{
  "name": "esmf-js",
  "version": "0.1.1",
  "type": "module",
  "description": "A library for building es-module native microfrontends",
  "author": "David Adamson",
  "license": "MIT",
  "keywords": [
    "microfrontends",
    "microservices",
    "esmf"
  ],
  "homepage": "https://github.com/adamsondavid/esmf#readme",
  "bugs": {
    "url": "https://github.com/adamsondavid/esmf/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adamsondavid/esmf.git"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "scripts": {
    "dev": "pnpm run build --watch",
    "check-types": "tsc --noEmit",
    "build": "tsdown src/index.ts --dts --minify --platform browser"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "typescript-config": "workspace:*"
  }
}
